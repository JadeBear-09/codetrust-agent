ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_PUBLISHED_PORT=8000
POSTGRES_DB=tnoc
POSTGRES_USER=tnoc
POSTGRES_PASSWORD=replace-with-local-secret
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
CHECKPOINT_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=tnoc-changeguard
TELEMETRY_TOPIC=tnoc.telemetry.v1
INCIDENT_TOPIC=tnoc.incident.v1
DECISION_TOPIC=tnoc.decision.v1
KNOWLEDGE_TOPIC=tnoc.knowledge.v1
EVENT_STREAM_CHANNEL=tnoc.dashboard.v1
SSE_HEARTBEAT_SECONDS=15
OUTBOX_POLL_INTERVAL_SECONDS=0.5
OUTBOX_BATCH_SIZE=100
WORKER_RETRY_DELAY_SECONDS=1
WORKER_RETRY_BACKOFF_MULTIPLIER=2
WORKER_RETRY_MAX_DELAY_SECONDS=30
WORKER_MAX_ATTEMPTS=5
KAFKA_AUTO_OFFSET_RESET=earliest
DEAD_LETTER_TOPIC=tnoc.dead-letter.v1
DATABASE_POOL_RECYCLE_SECONDS=1800
CORRELATION_WINDOW_SECONDS=300
CORRELATION_MIN_EVENT_COUNT=2
DASHBOARD_WINDOW_SECONDS=86400
DASHBOARD_RATE_WINDOW_SECONDS=60
DASHBOARD_INCIDENT_LIMIT=50
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.6-terra
LLM_REASONING_EFFORT=medium
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
PROOF_API_HOST=127.0.0.1
PROOF_API_PORT=8010
# Optional: Discovery API key. Auto mode uses cached fallback when absent or unavailable.
TICKETMASTER_API_KEY=
TICKETMASTER_KEYWORD=football
TICKETMASTER_COUNTRY_CODE=DE
RAN_DEMO_EVENT_MODE=auto
RAN_DEMO_CONFIG_PATH=config/ran-demo.json
RAN_DEMO_EVENT_CACHE_PATH=examples/events/stadium-event-fallback.json
RAN_DEMO_OUTPUT_ROOT=../outputs/ran-demo
OPENAI_STORE=false
MODEL_MAX_CONCURRENCY=4
MODEL_REQUESTS_PER_MINUTE=10
MODEL_TIMEOUT_SECONDS=90
MODEL_MAX_RETRIES=2
MODEL_RETRY_BASE_SECONDS=1
MODEL_RUN_LOG_DIRECTORY=../outputs/model-runs
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
RAG_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=tnoc-knowledge
RAG_CHUNK_CHARACTERS=2400
RAG_CHUNK_OVERLAP_CHARACTERS=300
RAG_RESULT_LIMIT=8
PROMPT_DIRECTORY=prompts
SPECIALIST_NAMES=["telemetry","topology","change_history","security"]
TOOL_CATALOG_PATH=config/tools.json
POLICY_PATH=config/policy.json
# Demo only: set TOOL_CATALOG_PATH=config/tools.sandbox.json when running compose.demo.yaml.
SANDBOX_CONTROLLER_URL=http://sandbox:8090
SANDBOX_HOST=0.0.0.0
SANDBOX_PORT=8090
OIDC_JWKS_URL=https://identity.example/.well-known/jwks.json
OIDC_ISSUER=https://identity.example/
OIDC_AUDIENCE=tnoc-api
OIDC_REQUIRED=true
DEVELOPMENT_TENANT_ID=
ALLOWED_ORIGINS=["https://tnoc.example"]
HTTP_TOOL_CONNECT_TIMEOUT_SECONDS=3
HTTP_TOOL_READ_TIMEOUT_SECONDS=30
MAX_TOOL_RESPONSE_BYTES=1048576
MAX_INGEST_PAYLOAD_BYTES=1048576
MAX_KNOWLEDGE_DOCUMENT_BYTES=10485760
MAX_OBSERVATION_FUTURE_SKEW_SECONDS=300
MAX_CONTEXT_EVENTS=500
MAX_CONTEXT_EVIDENCE=1000
OTEL_SERVICE_NAME=tnoc-changeguard
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACE_SAMPLE_RATIO=1.0
